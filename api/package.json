{
  "name": "yokup-api",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker — API de Yokup entre el frontend estático y Supabase (REST con service_role).",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "secret:url": "wrangler secret put SUPABASE_URL",
    "secret:key": "wrangler secret put SUPABASE_SERVICE_ROLE"
  },
  "devDependencies": {
    "wrangler": "^4.93.0"
  }
}
